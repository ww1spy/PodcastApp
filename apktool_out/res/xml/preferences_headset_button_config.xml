    <ListPreference android:entries="@array/settings_configure_bt_buttons_text" android:title="@string/settings_HeadsetButtons_DC_title" android:key="WRDoubleClickButtonAction" android:summary="@string/settings_HeadsetButtons_DC_summary" android:dependency="EnableHeadsetButton" android:defaultValue="1" android:dialogTitle="@string/settings_HeadsetButtons_DC_title" android:entryValues="@array/settings_configure_bt_buttons_values" />
</PreferenceScreen>